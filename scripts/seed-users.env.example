# Копирай като .env.local в root на проекта (или задай променливите в терминала).
# service_role вземи от Supabase → Settings → API (не го комитирай).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Поне един потребител (admin) — за локален сийд
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=change-me-8-chars-min

# По избор
# SEED_EDITOR_EMAIL=editor@local.test
# SEED_EDITOR_PASSWORD=change-me-too
# SEED_VIEWER_EMAIL=viewer@local.test
# SEED_VIEWER_PASSWORD=change-me-too
