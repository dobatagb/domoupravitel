# Copy to .env and fill from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Само за локален restore (scripts/restore-supabase-backup.ps1). НЕ се ползва от Vite/React.
# Вземи URI от Database → Connect (Session pooler). Не качвай в git ред с парола.
# SUPABASE_DB_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres
